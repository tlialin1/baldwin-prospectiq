# Baldwin Insurance - Lead Enrichment Module
# Environment Variables Configuration

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/baldwin_insurance
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baldwin_insurance
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================

# API Server
PORT=3001
NODE_ENV=development

# JWT & Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# ENRICHMENT SERVICE CONFIGURATION
# =============================================================================

# FastAPI Enrichment Service
ENRICHMENT_SERVICE_URL=http://localhost:8000
ENRICHMENT_SERVICE_HOST=0.0.0.0
ENRICHMENT_SERVICE_PORT=8000

# Enrichment Settings
ENRICHMENT_RATE_LIMIT=1000_per_day
ENRICHMENT_BATCH_SIZE=50
ENRICHMENT_TIMEOUT_SECONDS=30
USE_MOCK_APIS=true  # Set to false in production to use real APIs

# =============================================================================
# EXTERNAL API KEYS (Production Only)
# =============================================================================

# Zillow API
ZILLOW_API_KEY=your_zillow_api_key_here
ZILLOW_API_BASE_URL=https://api.zillow.com

# Data Axle (formerly Infogroup)
DATA_AXLE_API_KEY=your_data_axle_api_key_here
DATA_AXLE_API_BASE_URL=https://api.data-axle.com

# Whitepages
WHITEPAGES_API_KEY=your_whitepages_api_key_here
WHITEPAGES_API_BASE_URL=https://api.whitepages.com

# Social Profile APIs
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# =============================================================================
# AWS S3 CONFIGURATION (for file uploads)
# =============================================================================

ENABLE_S3_UPLOAD=false  # Set to true to enable S3 uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=baldwin-insurance-uploads

# =============================================================================
# TWILIO SMS CONFIGURATION (for agent notifications)
# =============================================================================

TWILIO_ENABLED=false  # Set to true to enable SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# =============================================================================
# LEAD SCORING & THRESHOLDS
# =============================================================================

HOT_LEAD_THRESHOLD=75
WARM_LEAD_THRESHOLD=50
COOL_LEAD_THRESHOLD=25
AUTO_ASSIGN_ENABLED=true
PRIORITY_QUEUE_ENABLED=true

# =============================================================================
# TRIGGER & AUTOMATION SETTINGS
# =============================================================================

SMS_NOTIFICATIONS_ENABLED=true
EMAIL_CAMPAIGNS_ENABLED=true
CRM_INTEGRATION_ENABLED=false  # Set to true to enable CRM sync
ADMIN_NOTIFICATIONS_ENABLED=true

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

LOG_LEVEL=info
LOG_FILE_PATH=./logs/enrichment_service.log
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# If serving frontend from backend
SERVE_FRONTEND=false
FRONTEND_BUILD_PATH=../frontend/build

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# CORS
CORS_ORIGIN_WHITELIST=http://localhost:3000,http://localhost:3001

# Helmet Headers
ENABLE_SECURITY_HEADERS=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Debug Mode
DEBUG_MODE=false
ENABLE_DETAILED_ERRORS=false  # Set to true for detailed error messages in development

# Hot Reload (Development only)
HOT_RELOAD=true

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# SSL/TLS (Production)
SSL_CERT_PATH=
SSL_KEY_PATH=
FORCE_HTTPS=true

# Process Management
CLUSTER_MODE=false  # Set to true to enable Node.js clustering
CLUSTER_WORKERS=4   # Number of worker processes

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Git
GITHUB_REPO_URL=https://github.com/your-org/baldwin-leads-module
DEPLOYMENT_BRANCH=main

# Docker
DOCKER_REGISTRY=your-registry.com
DOCKER_IMAGE=baldwin-leads-module

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
# IMPORTANT: 
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env files to version control
# 3. Keep API keys secure and rotate them regularly
# 4. Use environment-specific files (.env.production, .env.staging) as needed
# =============================================================================
